<UserControl x:Class="EasyJob_ProDG.UI.View.DialogWindows.SelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:EasyJob_ProDG.UI.View.Converters"
             mc:Ignorable="d"
             x:Name="Control">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BTVConverter" />
    </UserControl.Resources>
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

        <Grid HorizontalAlignment="Stretch"
              Background="White">
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment"
                            Value="Right" />
                </Style>
                <Style TargetType="ComboBox">
                    <Setter Property="HorizontalAlignment"
                            Value="Left" />
                    <Setter Property="MinWidth"
                            Value="100" />
                </Style>
                <Style TargetType="CheckBox">
                    <Setter Property="HorizontalAlignment"
                            Value="Left" />
                    <Setter Property="Margin"
                            Value="10 0 0 0" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition Height="Auto" />
                <!-- 8 -->
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Text="Container number" />
            <ComboBox Text="XXXX1234567"
                      Grid.Column="1"
                      Grid.Row="0" />

            <TextBlock Text="Position"
                       Grid.Row="1" />
            <TextBox Text="220688"
                     Grid.Column="1"
                     Grid.Row="1" />
            <TextBlock Text="Bay: any Row: any"
                       Grid.Column="1"
                       Grid.Row="2" />

            <TextBlock Text="Old Position"
                       Grid.Row="1"
                       Grid.Column="2" />
            <TextBox Text="220882"
                     Grid.Column="3"
                     Grid.Row="1" />
            <TextBlock Text="Bay: any Row: any"
                       Grid.Column="3"
                       Grid.Row="2" />

            <!-- Underdeck -->
            <CheckBox Content="Underdeck"
                      Grid.Row="3" />
            <CheckBox Content="On deck"
                      Grid.Row="3"
                      Grid.Column="1" />
            <!-- Unit type -->
            <CheckBox Content="Dg"
                      Grid.Row="4" />
            <CheckBox Content="Non-dg"
                      Grid.Row="4"
                      Grid.Column="1" />
            <CheckBox Content="Reefer"
                      Grid.Row="4"
                      Grid.Column="2" />
            <CheckBox Content="Non-reefer"
                      Grid.Row="4"
                      Grid.Column="3" />

            <!-- POL / POD / Operator / Final destination-->
            <TextBlock Text="POL"
                       Grid.Row="5" />
            <ComboBox Text="XXOPT"
                      Grid.Column="1"
                      Grid.Row="5" />

            <TextBlock Text="POD"
                       Grid.Row="6" />
            <ComboBox Text="XXOPT"
                      Grid.Column="1"
                      Grid.Row="6" />

            <TextBlock Text="Operator"
                       Grid.Row="5"
                       Grid.Column="2" />
            <ComboBox Text="MSC"
                      Grid.Column="3"
                      Grid.Row="5" />

            <TextBlock Text="Final destination"
                       Grid.Row="6"
                       Grid.Column="2" />
            <ComboBox Text="XXOPT"
                      Grid.Column="3"
                      Grid.Row="6" />

            <TextBlock Text="Container type"
                       Grid.Row="7" />
            <ComboBox Text="42G0"
                      Grid.Column="1"
                      Grid.Row="7" />
            <CheckBox Content="Open type"
                      Grid.Row="7"
                      Grid.Column="2" />

            <!-- Remarks -->
            <CheckBox Content="Has remarks"
                      Grid.Row="8" />
            <CheckBox Content="not"
                      Grid.Row="8"
                      Grid.Column="1" />

            <Border Grid.Row="8"
                    Grid.ColumnSpan="4"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    BorderThickness="1"
                    BorderBrush="Black" />
            <!-- Changes -->
            <Expander Grid.Row="9"
                      Grid.ColumnSpan="4"
                      Header="Changes"
                      IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <CheckBox Content="New in plan"
                              Grid.Row="0" />
                    <CheckBox Content="not"
                              Grid.Row="0"
                              Grid.Column="1" />

                    <CheckBox Content="Position changed"
                              Grid.Row="1" />
                    <CheckBox Content="not"
                              Grid.Row="1"
                              Grid.Column="1" />

                    <CheckBox Content="Updated"
                              Grid.Row="2" />
                    <CheckBox Content="not"
                              Grid.Row="2"
                              Grid.Column="1" />

                    <CheckBox Content="POD changed"
                              Grid.Row="0"
                              Grid.Column="2" />
                    <CheckBox Content="not"
                              Grid.Row="0"
                              Grid.Column="3" />
                    <CheckBox Content="Type changed"
                              Grid.Row="1"
                              Grid.Column="2" />
                    <CheckBox Content="not"
                              Grid.Row="1"
                              Grid.Column="3" />

                    <!-- Updatable -->
                    <CheckBox Content="Is Locked"
                              Grid.Row="3" />
                    <CheckBox Content="not"
                              Grid.Row="3"
                              Grid.Column="1" />

                    <CheckBox Content="To import"
                              Grid.Row="4" />
                    <CheckBox Content="Not to import"
                              Grid.Row="4"
                              Grid.Column="1" />

                    <CheckBox Content="To be kept in plan"
                              Grid.Row="3"
                              Grid.Column="2" />
                    <CheckBox Content="not"
                              Grid.Row="3"
                              Grid.Column="3" />

                </Grid>
            </Expander>


            <!-- Dg -->
            <Expander Grid.Row="10"
                      Grid.ColumnSpan="4"
                      Header="Dg"
                      IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!-- Unno -->
                    <TextBlock Text="UNNO"
                               Grid.Row="0"
                               Grid.Column="0" />
                    <ComboBox Text="2216"
                              Grid.Column="1"
                              Grid.Row="0" />
                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal">
                        <Button Content="+"
                                ToolTip="Add another UNNO" />
                        <Button Content="2216" />
                        <Button Content="3080" />
                        <Button HorizontalAlignment="Right"
                                Content="x"
                                ToolTip="Clear selection" />
                    </StackPanel>

                    <!-- Dg class -->
                    <TextBlock Text="Dg class"
                               Grid.Row="1"
                               Grid.Column="0" />
                    <ComboBox Text="2.1"
                              Grid.Column="1"
                              Grid.Row="1" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal">
                        <Button Content="+"
                                ToolTip="Add another class" />
                        <Button Content="2.1" />
                        <Button Content="3" />
                        <Button HorizontalAlignment="Right"
                                Content="x"
                                ToolTip="Clear selection" />
                    </StackPanel>

                    <!-- Flash point -->
                    <TextBlock Text="Flash point"
                               Grid.Row="2"
                               Grid.Column="0" />
                    <TextBox Text="+30"
                             Grid.Column="3"
                             Grid.Row="2" />
                    <CheckBox Content="less than"
                              Grid.Row="2"
                              Grid.Column="1" />
                    <CheckBox Content="more than"
                              Grid.Row="2"
                              Grid.Column="2" />

                    <!-- Conflicted -->
                    <CheckBox Content="Conflicted"
                              Grid.Row="3" />
                    <CheckBox Content="not"
                              Grid.Row="3"
                              Grid.Column="1" />
                    <!-- Remarks -->
                    <CheckBox Content="Has remarks"
                              Grid.Row="4" />
                    <CheckBox Content="not"
                              Grid.Row="4"
                              Grid.Column="1" />
                </Grid>
            </Expander>

            <!-- Reefer -->
            <Expander Grid.Row="11"
                      Grid.ColumnSpan="4"
                      Header="Reefers"
                      IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!-- Has properties -->
                    <CheckBox Content="Commodity"
                              Grid.Row="0" />
                    <CheckBox Content="not"
                              Grid.Row="0"
                              Grid.Column="1" />

                    <CheckBox Content="Special"
                              Grid.Row="0"
                              Grid.Column="2" />
                    <CheckBox Content="not"
                              Grid.Row="0"
                              Grid.Column="3" />

                    <CheckBox Content="Has remarks"
                              Grid.Row="1" />
                    <CheckBox Content="not"
                              Grid.Row="1"
                              Grid.Column="1" />

                    <!-- Set point -->
                    <TextBlock Text="Set point"
                               Grid.Row="2"
                               Grid.Column="0" />
                    <TextBox Text="+30"
                             Grid.Column="3"
                             Grid.Row="2" />
                    <CheckBox Content="less than"
                              Grid.Row="2"
                              Grid.Column="1" />
                    <CheckBox Content="more than"
                              Grid.Row="2"
                              Grid.Column="2" />
                </Grid>
            </Expander>


            <TextBlock Text="Search text"
                       Grid.Row="20"
                       Grid.Column="1" />
            <TextBox  Text="Search free text"
                      Grid.Column="2"
                      Grid.Row="20" />
        </Grid>

    </ScrollViewer>
</UserControl>