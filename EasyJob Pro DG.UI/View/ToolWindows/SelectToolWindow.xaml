<base:AnimatedWindow x:Class="EasyJob_ProDG.UI.View.DialogWindows.SelectToolWindow"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                            xmlns:base="clr-namespace:EasyJob_ProDG.UI.View.WindowBase"
                            xmlns:local="clr-namespace:EasyJob_ProDG.UI.View.DialogWindows"
                            mc:Ignorable="d"
                            Height="600"
                            Width="400"
                            Style="{StaticResource SummaryWindowStyle}"
                            WindowStartupLocation="CenterScreen"
                            MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid TextBlock.FontSize="11">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Capture -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Selection tool"
                       Style="{StaticResource WindowTitleTextBlock}" />
            <Button Content="Clear"
                    Command="{Binding ApplyMergePortNamesCommand}"
                    HorizontalAlignment="Right"
                    Grid.Column="1" />
        </Grid>

        <!-- Main working part -->
        <local:SelectionControl Grid.Row="1" />
        
        <!-- Control buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="4"
                    Grid.ColumnSpan="2">
            <StackPanel.Resources>
                <Style TargetType="{x:Type Button}"
                       BasedOn="{StaticResource SummaryWindowButtonStyle}">
                </Style>
            </StackPanel.Resources>
            <Button Content="Select"
                    Command="{Binding ApplyMergePortNamesCommand}"
                    IsDefault="True" />
            <Button Content="Close"
                    Click="CloseWindow"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AnimatedWindow>
