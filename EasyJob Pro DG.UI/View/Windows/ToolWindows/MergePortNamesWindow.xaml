<base:AnimatedToolWindow x:Class="EasyJob_ProDG.UI.View.DialogWindows.MergePortNamesWindow"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:base="clr-namespace:EasyJob_ProDG.UI.View.WindowBase"
                         xmlns:local="clr-namespace:EasyJob_ProDG.UI.View.DialogWindows"
                         mc:Ignorable="d"
                         Width="200"
                         MinWidth="200"
                         Style="{StaticResource ToolWindowStyle}"
                         Focusable="True"
                         WindowStartupLocation="CenterScreen"
                         MouseLeftButtonDown="Window_MouseLeftButtonDown"
                         Activated="OnGotFocusHandler"
                         Deactivated="OnLostFocusHandler"
                         >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Capture -->
        <TextBlock Text="Merge Port Names"
                   Style="{StaticResource WindowTitleTextBlock}" />

        <!-- Main working part -->
        <StackPanel Orientation="Vertical"
                    Background="AliceBlue"
                    HorizontalAlignment="Stretch"
                    Margin="2"
                    Grid.Row="1">
            <StackPanel.Resources>
                <Style TargetType="ComboBox">
                    <Setter Property="IsEditable"
                            Value="True" />
                    <Setter Property="StaysOpenOnEdit"
                            Value="True" />
                    <Setter Property="ItemsSource"
                            Value="{Binding ListOfPorts}" />
                    <Setter Property="MinWidth"
                            Value="100" />
                    <Setter Property="HorizontalAlignment"
                            Value="Left" />
                </Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Orientation"
                            Value="Horizontal" />
                    <Setter Property="Margin"
                            Value="5 5 0 0" />
                </Style>
                <Style TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment"
                            Value="Right" />
                    <Setter Property="Margin"
                            Value="10 0" />
                    <Setter Property="Text"
                            Value="Port:" />
                </Style>
            </StackPanel.Resources>

            <StackPanel>
                <TextBlock />
                <ComboBox SelectedValue="{Binding SelectedPort1}" />
            </StackPanel>
            <StackPanel>
                <TextBlock />
                <ComboBox SelectedValue="{Binding SelectedPort2}" />
            </StackPanel>
            <StackPanel>
                <TextBlock />
                <ComboBox SelectedValue="{Binding SelectedPort3}" />
            </StackPanel>

            <TextBlock Text="{Binding MergePortsText}"
                       Margin="10 10 10 0"
                       HorizontalAlignment="Left"
                       TextWrapping="Wrap" />
            <ComboBox SelectedItem="{Binding MergeResultingPort}"
                      Text="{Binding MergeResultingPort, UpdateSourceTrigger=PropertyChanged}"
                      Width="100"
                      Margin="50 2 0 10" />
        </StackPanel>

        <!-- Control buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="4"
                    Grid.ColumnSpan="2">
            <StackPanel.Resources>
                <Style TargetType="{x:Type Button}"
                       BasedOn="{StaticResource SummaryWindowButtonStyle}">
                </Style>
            </StackPanel.Resources>
            <Button Content="Apply"
                    Command="{Binding ApplyMergePortNamesCommand}"
                    IsDefault="True" />
            <Button Content="Close"
                    Click="CloseWindow"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AnimatedToolWindow>
