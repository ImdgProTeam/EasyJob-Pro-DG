<base:AnimatedToolWindow x:Class="EasyJob_ProDG.UI.View.DialogWindows.FilterToolWindow"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:base="clr-namespace:EasyJob_ProDG.UI.View.WindowBase"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:local="clr-namespace:EasyJob_ProDG.UI.View.DialogWindows"
                         xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
                         mc:Ignorable="d"
                         Height="450"
                         Width="400"
                         Style="{StaticResource ToolWindowStyle}"
                         WindowStartupLocation="CenterScreen"
                         MouseLeftButtonDown="Window_MouseLeftButtonDown"
                         Activated="OnGotFocusHandler"
                         Deactivated="OnLostFocusHandler">
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Closed">
            <b:CallMethodAction MethodName="OnWindowClosed"
                                TargetObject="{Binding}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SummaryWindowButtonStyle}">
            </Style>
        </Grid.Resources>

        <!-- Capture -->
        <TextBlock Text="Filter tool"
                   Style="{StaticResource WindowTitleTextBlock}" 
                   HorizontalAlignment="Left"/>
        <Button Content="Clear"
                Command="{Binding ClearCommand}"
                HorizontalAlignment="Right"
                Grid.Column="1"
                Style="{StaticResource ButtonClearStyle}"
                FontSize="15"
                Padding="20 5"/>

        <!-- Main working part -->
        <local:SelectionControl Grid.Row="1"
                                DataContext="{Binding SelectionControlViewModel}"
                                Margin="2"/>

        <!-- Status text -->
        <TextBlock Grid.Row="4"
                   Margin="5 0"
                   Text="{Binding StatusBarText, FallbackValue='No filter applied'}" />
        
        <!-- Control buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="4"
                    Grid.ColumnSpan="2">
            <StackPanel.Resources>
            </StackPanel.Resources>
            <Button Content="{Binding FilterButtonText, FallbackValue='Filter'}"
                    Command="{Binding ApplyCommand}"
                    IsDefault="True" />
            <Button Content="Close"
                    Click="CloseWindow"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AnimatedToolWindow>
