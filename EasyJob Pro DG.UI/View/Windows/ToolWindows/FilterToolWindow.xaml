<base:AnimatedToolWindow x:Class="EasyJob_ProDG.UI.View.DialogWindows.FilterToolWindow"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:base="clr-namespace:EasyJob_ProDG.UI.View.WindowBase"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:local="clr-namespace:EasyJob_ProDG.UI.View.DialogWindows"
                         mc:Ignorable="d"
                         Height="450"
                         Width="400"
                         Style="{StaticResource ToolWindowStyle}"
                         WindowStartupLocation="CenterScreen"
                         MouseLeftButtonDown="Window_MouseLeftButtonDown"
                         Activated="OnGotFocusHandler"
                         Deactivated="OnLostFocusHandler">
    <Grid TextBlock.FontSize="11">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="{x:Type Button}"
                   BasedOn="{StaticResource SummaryWindowButtonStyle}">
            </Style>
        </Grid.Resources>

        <!-- Capture -->
        <TextBlock Text="Filter tool"
                   Style="{StaticResource WindowTitleTextBlock}" />
        <Button Content="Clear"
                Command="{Binding ClearCommand}"
                HorizontalAlignment="Right"
                Panel.ZIndex="100"
                Grid.Column="1" />

        <!-- Main working part -->
        <local:SelectionControl Grid.Row="1"
                                DataContext="{Binding SelectionControlViewModel}" />

        <!-- Control buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="4"
                    Grid.ColumnSpan="2">
            <StackPanel.Resources>
            </StackPanel.Resources>
            <Button Content="Filter"
                    Command="{Binding ApplyCommand}"
                    IsDefault="True" />
            <Button Content="Close"
                    Click="CloseWindow"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</base:AnimatedToolWindow>
